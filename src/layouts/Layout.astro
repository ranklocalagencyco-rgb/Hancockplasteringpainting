---
export interface Props {
  title?: string;
  description?: string;
  activePage?: '' | 'home' | 'services' | 'areas' | 'gallery' | 'blog' | 'about' | 'contact';
  extraSchema?: Record<string, unknown>[];
}

const {
  title = 'Hancock Plastering & Painting Services',
  description = 'Plastering and painting contractors serving Middlesex and the Home Counties. Fixed-price quotes. City & Guilds certified. No subcontractors.',
  activePage = '',
  extraSchema = [],
} = Astro.props;

import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Faq from '../components/Faq.astro';
import { schemaFor, SITE_URL, BUSINESS } from '../lib/business';
import { getFaqs, faqSchema } from '../lib/faqs';

const canonical = SITE_URL + (Astro.url.pathname !== '/' ? Astro.url.pathname.replace(/\/$/, '') : '');
const jsonld = schemaFor(Astro.url.pathname, title, description);

const faqs = getFaqs(Astro.url.pathname);
if (faqs) jsonld.push(faqSchema(faqs.items));

// Page-supplied schema (e.g. BlogPosting on dynamic blog routes).
for (const block of extraSchema) jsonld.push(block);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={BUSINESS.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={BUSINESS.logo} />
    <meta name="twitter:card" content="summary" />

    <!-- JSON-LD structured data -->
    {jsonld.map((block) => (
      <script type="application/ld+json" is:inline set:html={JSON.stringify(block)} />
    ))}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;500;600;700;800&family=Inter:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <Nav activePage={activePage} />
    <slot />
    {faqs && <Faq heading={faqs.heading} items={faqs.items} />}
    <Footer />

    <!-- Generic hover handler: replicates Claude Design's style-hover attribute -->
    <script is:inline>
      document.querySelectorAll('[style-hover]').forEach((el) => {
        const base = el.getAttribute('style') || '';
        const hover = el.getAttribute('style-hover') || '';
        el.addEventListener('mouseenter', () => el.setAttribute('style', base + ';' + hover));
        el.addEventListener('mouseleave', () => el.setAttribute('style', base));
      });
    </script>
  </body>
</html>

<style is:global>
  body {
    margin: 0;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }
</style>
