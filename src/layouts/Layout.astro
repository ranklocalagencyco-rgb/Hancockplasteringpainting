---
export interface Props {
  title?: string;
  description?: string;
  activePage?: '' | 'home' | 'services' | 'areas' | 'gallery' | 'blog' | 'about' | 'contact';
  extraSchema?: Record<string, unknown>[];
}

const {
  title = 'Hancock Plastering & Painting Services',
  description = 'Plastering & painting contractors across Middlesex & the Home Counties. Fixed-price quotes, City & Guilds certified.',
  activePage = '',
  extraSchema = [],
} = Astro.props;

import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Faq from '../components/Faq.astro';
import GallerySnippet from '../components/GallerySnippet.astro';
import BlogInsights from '../components/BlogInsights.astro';
import { schemaFor, SITE_URL, BUSINESS } from '../lib/business';
import { getFaqs, faqSchema } from '../lib/faqs';

const path = Astro.url.pathname !== '/' ? Astro.url.pathname.replace(/\/$/, '') : '/';
const canonical = SITE_URL + (path === '/' ? '' : path);
// Dedicated 1200x630 social share image (Open Graph / Twitter).
const ogImage = SITE_URL + '/og-image.png';
const jsonld = schemaFor(Astro.url.pathname, title, description);

const faqs = getFaqs(Astro.url.pathname);
if (faqs) jsonld.push(faqSchema(faqs.items));

// Service + area pages (hubs and detail pages) get extra gallery + blog
// sections to add depth.
const isDetailPage = /^\/(services|areas)(\/[a-z0-9-]+)?$/.test(path);

// Page-supplied schema (e.g. BlogPosting on dynamic blog routes).
for (const block of extraSchema) jsonld.push(block);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <!-- Site is designed light-only. Declaring this stops Samsung Internet /
         Chrome "force dark" from inverting the white UI and hiding the logo. -->
    <meta name="color-scheme" content="only light" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <!-- Bing Webmaster Tools site verification -->
    <meta name="msvalidate.01" content="D7B1A43A1F88DD9D6B52B7C3F0100798" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="192x192" href="/icon-192.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={BUSINESS.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={BUSINESS.name} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- JSON-LD structured data -->
    {jsonld.map((block) => (
      <script type="application/ld+json" is:inline set:html={JSON.stringify(block)} />
    ))}
    <!-- Self-hosted variable fonts: same-origin, no third-party request,
         preloaded so the swap happens once and early. -->
    <link rel="preload" as="font" type="font/woff2" href="/fonts/inter-latin-wght-normal.woff2" crossorigin />
    <link rel="preload" as="font" type="font/woff2" href="/fonts/lexend-latin-wght-normal.woff2" crossorigin />
  </head>
  <body>
    <Nav activePage={activePage} />
    <main>
      <slot />
      {isDetailPage && <GallerySnippet />}
      {isDetailPage && <BlogInsights />}
      {faqs && <Faq heading={faqs.heading} items={faqs.items} />}
    </main>
    <Footer />

    <!-- Generic hover handler: replicates Claude Design's style-hover attribute.
         Skipped on touch/non-hover devices (no hover) and deferred to idle so
         it never blocks the main thread during load. -->
    <script is:inline>
      (function () {
        if (!window.matchMedia || !window.matchMedia('(hover: hover)').matches) return;
        function init() {
          document.querySelectorAll('[style-hover]').forEach((el) => {
            const base = el.getAttribute('style') || '';
            const hover = el.getAttribute('style-hover') || '';
            el.addEventListener('mouseenter', () => el.setAttribute('style', base + ';' + hover));
            el.addEventListener('mouseleave', () => el.setAttribute('style', base));
          });
        }
        if ('requestIdleCallback' in window) requestIdleCallback(init);
        else setTimeout(init, 200);
      })();
    </script>
  </body>
</html>

<style is:global>
  @font-face {
    font-family: 'Inter';
    font-style: normal;
    font-display: swap;
    font-weight: 100 900;
    src: url('/fonts/inter-latin-wght-normal.woff2') format('woff2-variations');
    unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;
  }
  @font-face {
    font-family: 'Lexend';
    font-style: normal;
    font-display: swap;
    font-weight: 100 900;
    src: url('/fonts/lexend-latin-wght-normal.woff2') format('woff2-variations');
    unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;
  }
  :root {
    color-scheme: only light;
  }
  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }
  body {
    margin: 0;
    font-family: 'Inter', sans-serif;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }
  /* Media never overflows its container on small screens */
  img,
  svg,
  iframe,
  video {
    max-width: 100%;
  }
  /* Form controls don't inherit font-family by default */
  input,
  select,
  textarea,
  button {
    font-family: inherit;
  }

  /* ------------------------------------------------------------------
     Responsive layer.
     Pages use inline styles, which can't hold media queries, so we
     collapse the fixed-column grids here via attribute selectors. This
     keeps every page responsive from one place. Substrings must match
     the inline `grid-template-columns` values exactly.
     ------------------------------------------------------------------ */
  @media (max-width: 768px) {
    /* 4-up stats bar -> 2x2 */
    [style*="grid-template-columns:repeat(4,1fr)"] {
      grid-template-columns: repeat(2, 1fr) !important;
    }
  }
  @media (max-width: 600px) {
    /* 3-up image grids -> 2-up */
    [style*="grid-template-columns:repeat(3,1fr)"] {
      grid-template-columns: repeat(2, 1fr) !important;
    }
    /* paired columns (form fields, before/after images) -> single column */
    [style*="grid-template-columns:1fr 1fr"] {
      grid-template-columns: 1fr !important;
    }
  }
</style>
