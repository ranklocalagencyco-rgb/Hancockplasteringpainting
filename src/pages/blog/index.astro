---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const fmtDate = (d: Date) =>
  d.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
---

<Layout
  title="Plastering & Painting Advice | Hancock Blog"
  description="Practical advice on plastering, rendering, skimming and painting from Hancock Plastering & Painting — serving Middlesex and the Home Counties."
  activePage="blog"
>
<!-- HERO -->
<section style="position:relative;height:300px;display:flex;align-items:flex-end;">
  <div style="position:absolute;top:0;left:0;right:0;bottom:0;background-image:url('/uploads/Hancock-plastering-and-painting%20(9).webp');background-size:cover;background-position:center 40%;"></div>
  <div style="position:absolute;top:0;left:0;right:0;bottom:0;background:linear-gradient(to top,rgba(15,23,42,0.92) 0%,rgba(15,23,42,0.5) 55%,rgba(15,23,42,0.18) 100%);"></div>
  <div style="position:relative;z-index:1;max-width:1280px;margin:0 auto;padding:0 24px 48px;width:100%;box-sizing:border-box;">
    <p style="font-family:'Inter',sans-serif;font-size:12px;color:rgba(255,255,255,0.55);margin:0 0 12px;"><a href="/" style="color:rgba(255,255,255,0.55);text-decoration:none;">Home</a> / Blog</p>
    <h1 style="font-family:'Lexend',sans-serif;font-size:clamp(32px,5vw,54px);font-weight:700;color:#ffffff;margin:0 0 12px;letter-spacing:-0.04em;line-height:1.05;">Advice &amp; insights.</h1>
    <p style="font-family:'Inter',sans-serif;font-size:17px;color:rgba(255,255,255,0.72);margin:0;">Honest, practical guidance on plastering, rendering and painting.</p>
  </div>
</section>

<!-- POSTS -->
<section style="padding:72px 24px 96px;background:#F8FAFC;">
  <div style="max-width:1280px;margin:0 auto;">
    {posts.length === 0 ? (
      <p style="font-family:'Inter',sans-serif;font-size:16px;color:#64748B;text-align:center;padding:40px 0;">New articles are on the way — check back soon.</p>
    ) : (
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:24px;">
        {posts.map((post) => (
          <a href={`/blog/${post.id}`} style="display:flex;flex-direction:column;background:#ffffff;border:1px solid #E2E8F0;border-radius:10px;overflow:hidden;text-decoration:none;" style-hover="box-shadow:0 8px 28px rgba(0,0,0,0.08);border-color:#D0E7F5;">
            {post.data.heroImage && (
              <div style="aspect-ratio:16/9;background:#F1F5F9;overflow:hidden;">
                <img src={post.data.heroImage} alt={post.data.title} title={post.data.title} loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;" />
              </div>
            )}
            <div style="padding:24px;display:flex;flex-direction:column;flex:1;">
              <p style="font-family:'Inter',sans-serif;font-size:12px;font-weight:600;color:#0C7BA8;letter-spacing:0.06em;text-transform:uppercase;margin:0 0 10px;">{fmtDate(post.data.pubDate)}</p>
              <h2 style="font-family:'Lexend',sans-serif;font-size:20px;font-weight:600;color:#0F172A;margin:0 0 10px;letter-spacing:-0.02em;line-height:1.25;">{post.data.title}</h2>
              <p style="font-family:'Inter',sans-serif;font-size:14px;color:#64748B;line-height:1.65;margin:0 0 18px;flex:1;">{post.data.description}</p>
              <span style="font-family:'Inter',sans-serif;font-size:14px;font-weight:500;color:#0C7BA8;">Read article →</span>
            </div>
          </a>
        ))}
      </div>
    )}
  </div>
</section>
</Layout>
