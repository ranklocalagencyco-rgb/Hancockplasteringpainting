---
import Layout from '../layouts/Layout.astro';
// Web3Forms access key — set PUBLIC_WEB3FORMS_KEY in .env (see .env.example).
const WEB3FORMS_KEY = import.meta.env.PUBLIC_WEB3FORMS_KEY ?? '';
---

<Layout
  title="Get a Free Quote | Hancock Plastering & Painting Services"
  description="Get a fixed-price quote for plastering or painting across Middlesex and the Home Counties. No obligation — Oliver usually responds within 24 hours."
  activePage="contact"
>
<!-- HERO -->
<section style="position:relative;height:340px;display:flex;align-items:flex-end;">
  <div style="position:absolute;top:0;left:0;right:0;bottom:0;background-image:url('/uploads/Hancock-plastering-and-painting%20(2).webp');background-size:cover;background-position:center 30%;"></div>
  <div style="position:absolute;top:0;left:0;right:0;bottom:0;background:linear-gradient(to top,rgba(15,23,42,0.92) 0%,rgba(15,23,42,0.5) 55%,rgba(15,23,42,0.18) 100%);"></div>
  <div style="position:relative;z-index:1;max-width:1280px;margin:0 auto;padding:0 24px 52px;width:100%;box-sizing:border-box;">
    <p style="font-size:12px;color:rgba(255,255,255,0.55);margin:0 0 12px;"><a href="/" style="color:rgba(255,255,255,0.55);text-decoration:none;">Home</a> / Contact</p>
    <h1 style="font-family:'Lexend',sans-serif;font-size:clamp(32px,5vw,54px);font-weight:700;color:#ffffff;margin:0 0 12px;letter-spacing:-0.04em;line-height:1.05;">Get a free quote.</h1>
    <p style="font-size:17px;color:rgba(255,255,255,0.72);margin:0;">Fixed price agreed before work starts. No obligation.</p>
  </div>
</section>

<!-- FORM + DETAILS -->
<section style="padding:72px 24px 96px;background:#ffffff;">
  <div style="max-width:1280px;margin:0 auto;display:flex;gap:64px;align-items:flex-start;flex-wrap:wrap;">

    <!-- FORM -->
    <div style="flex:1.4;min-width:300px;">
      <div id="contact-success" style="display:none;background:#F0FDF4;border:1px solid #86EFAC;border-radius:8px;padding:40px;text-align:center;">
        <div style="width:56px;height:56px;background:#15803D;border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 20px;">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M5 12L10 17L19 8" stroke="#ffffff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"></path></svg>
        </div>
        <h3 style="font-family:'Lexend',sans-serif;font-size:24px;font-weight:600;color:#0F172A;margin:0 0 12px;letter-spacing:-0.02em;">Enquiry sent.</h3>
        <p style="font-size:16px;color:#334155;line-height:1.65;margin:0 0 24px;">Thanks for getting in touch. Oliver will be in contact shortly to discuss your project and provide a fixed-price quote.</p>
        <p style="font-size:14px;color:#64748B;margin:0;">In a hurry? Call directly: <a href="tel:07734903439" style="color:#0C7BA8;text-decoration:none;font-weight:500;">07734 903439</a></p>
      </div>
      <div id="contact-form-wrap">
        <h2 style="font-family:'Lexend',sans-serif;font-size:clamp(22px,3vw,30px);font-weight:600;color:#0F172A;margin:0 0 8px;letter-spacing:-0.03em;">Tell us about your project.</h2>
        <p style="font-size:15px;color:#64748B;margin:0 0 32px;line-height:1.6;">Fill in the form and Oliver will come back to you with a fixed-price quote, usually within 24 hours.</p>
        <form id="contact-form" style="display:flex;flex-direction:column;gap:20px;">
          <input type="hidden" name="access_key" value={WEB3FORMS_KEY} />
          <input type="hidden" name="subject" value="New website enquiry — Hancock Plastering & Painting" />
          <input type="hidden" name="from_name" value="Hancock Plastering Website" />
          <!-- honeypot: bots fill this, humans don't -->
          <input type="checkbox" name="botcheck" tabindex="-1" autocomplete="off" style="display:none;" />
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
            <div>
              <label style="display:block;font-size:13px;font-weight:600;color:#0F172A;margin-bottom:6px;letter-spacing:-0.01em;">Full name *</label>
              <input type="text" name="name" required placeholder="Your name" style="width:100%;box-sizing:border-box;padding:11px 14px;border:1px solid #E2E8F0;border-radius:6px;font-size:15px;color:#0F172A;background:#ffffff;outline:none;" />
            </div>
            <div>
              <label style="display:block;font-size:13px;font-weight:600;color:#0F172A;margin-bottom:6px;letter-spacing:-0.01em;">Phone number *</label>
              <input type="tel" name="phone" required placeholder="07700 000000" style="width:100%;box-sizing:border-box;padding:11px 14px;border:1px solid #E2E8F0;border-radius:6px;font-size:15px;color:#0F172A;background:#ffffff;outline:none;" />
            </div>
          </div>
          <div>
            <label style="display:block;font-size:13px;font-weight:600;color:#0F172A;margin-bottom:6px;letter-spacing:-0.01em;">Email address *</label>
            <input type="email" name="email" required placeholder="your@email.com" style="width:100%;box-sizing:border-box;padding:11px 14px;border:1px solid #E2E8F0;border-radius:6px;font-size:15px;color:#0F172A;background:#ffffff;outline:none;" />
          </div>
          <div>
            <label style="display:block;font-size:13px;font-weight:600;color:#0F172A;margin-bottom:6px;letter-spacing:-0.01em;">Service required</label>
            <select name="service" style="width:100%;box-sizing:border-box;padding:11px 14px;border:1px solid #E2E8F0;border-radius:6px;font-size:15px;color:#334155;background:#ffffff;outline:none;appearance:auto;">
              <option value="">Select a service...</option>
              <option>Plastering</option>
              <option>Skimming</option>
              <option>Rendering</option>
              <option>Pebble Dashing</option>
              <option>Venetian Plastering</option>
              <option>Floating Plaster</option>
              <option>Plaster Refurbishment</option>
              <option>Repair &amp; Insurance Work</option>
              <option>Interior Painting</option>
              <option>Exterior Painting</option>
              <option>Wallpapering</option>
              <option>Sash Window Painting</option>
              <option>Commercial Decorating</option>
              <option>Eco-Friendly Decorating</option>
            </select>
          </div>
          <div>
            <label style="display:block;font-size:13px;font-weight:600;color:#0F172A;margin-bottom:6px;letter-spacing:-0.01em;">Your location / postcode</label>
            <input type="text" name="location" placeholder="e.g. Ruislip HA4" style="width:100%;box-sizing:border-box;padding:11px 14px;border:1px solid #E2E8F0;border-radius:6px;font-size:15px;color:#0F172A;background:#ffffff;outline:none;" />
          </div>
          <div>
            <label style="display:block;font-size:13px;font-weight:600;color:#0F172A;margin-bottom:6px;letter-spacing:-0.01em;">Tell us about the job</label>
            <textarea name="message" rows="5" placeholder="Describe what needs doing — wall condition, room size, any relevant details..." style="width:100%;box-sizing:border-box;padding:11px 14px;border:1px solid #E2E8F0;border-radius:6px;font-size:15px;color:#0F172A;background:#ffffff;outline:none;resize:vertical;line-height:1.6;"></textarea>
          </div>
          <div style="padding:16px;background:#FFF8ED;border:1px solid #FDE68A;border-radius:6px;">
            <p style="font-size:13px;color:#92400E;margin:0;line-height:1.6;">⚠ Please be aware: cancellations made less than 48 hours before your booking incur a £100 cancellation fee.</p>
          </div>
          <button id="contact-submit" type="submit" style="background:#0C7BA8;color:#ffffff;font-size:16px;font-weight:600;padding:15px 28px;border-radius:6px;border:none;cursor:pointer;letter-spacing:-0.02em;text-align:left;display:flex;align-items:center;justify-content:space-between;">Send Enquiry <span style="font-size:20px;">→</span></button>
          <p id="contact-error" style="display:none;font-size:14px;color:#B91C1C;background:#FEF2F2;border:1px solid #FECACA;border-radius:6px;padding:12px 14px;margin:0;line-height:1.6;"></p>
        </form>
      </div>
    </div>

    <!-- DETAILS -->
    <div style="flex:1;min-width:260px;">
      <h3 style="font-family:'Lexend',sans-serif;font-size:20px;font-weight:600;color:#0F172A;margin:0 0 28px;letter-spacing:-0.02em;">Contact details</h3>
      <div style="display:flex;flex-direction:column;gap:20px;margin-bottom:40px;">
        <div style="display:flex;align-items:flex-start;gap:14px;">
          <div style="width:36px;height:36px;background:#E0FAFF;border-radius:8px;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:2px;">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M2 2.5C2 2.5 2.5 2 3.5 2S5.5 4 5.5 4.5 4.5 5 4.5 6 7.5 10 8.5 10 9.5 9 10 9 12 10 12 11 11.5 12 11.5 12C11 12.5 10 13 8.5 13 5.5 13 1 7.5 1 4.5 1 3 1.5 2 2 2.5Z" stroke="#0C7BA8" stroke-width="1.3" fill="none"></path></svg>
          </div>
          <div>
            <p style="font-size:13px;font-weight:600;color:#64748B;margin:0 0 4px;text-transform:uppercase;letter-spacing:0.06em;">Phone</p>
            <a href="tel:07734903439" style="font-size:16px;font-weight:500;color:#0F172A;text-decoration:none;">07734 903439</a>
            <p style="font-size:13px;color:#64748B;margin:2px 0 0;">Anytime — Oliver answers directly</p>
          </div>
        </div>
        <div style="display:flex;align-items:flex-start;gap:14px;">
          <div style="width:36px;height:36px;background:#E0FAFF;border-radius:8px;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:2px;">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><rect x="1.5" y="3.5" width="13" height="9" rx="1" stroke="#0C7BA8" stroke-width="1.3"></rect><path d="M1.5 5L8 9L14.5 5" stroke="#0C7BA8" stroke-width="1.3" stroke-linecap="round"></path></svg>
          </div>
          <div>
            <p style="font-size:13px;font-weight:600;color:#64748B;margin:0 0 4px;text-transform:uppercase;letter-spacing:0.06em;">Email</p>
            <a href="mailto:hancockplasteringpainting@gmail.com" style="font-size:15px;font-weight:500;color:#0F172A;text-decoration:none;word-break:break-all;">hancockplasteringpainting@gmail.com</a>
          </div>
        </div>
        <div style="display:flex;align-items:flex-start;gap:14px;">
          <div style="width:36px;height:36px;background:#E0FAFF;border-radius:8px;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:2px;">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M8 1.5C5.5 1.5 3.5 3.5 3.5 6C3.5 9.5 8 14.5 8 14.5S12.5 9.5 12.5 6C12.5 3.5 10.5 1.5 8 1.5Z" stroke="#0C7BA8" stroke-width="1.3" fill="none"></path><circle cx="8" cy="6" r="1.5" stroke="#0C7BA8" stroke-width="1.3" fill="none"></circle></svg>
          </div>
          <div>
            <p style="font-size:13px;font-weight:600;color:#64748B;margin:0 0 4px;text-transform:uppercase;letter-spacing:0.06em;">Based</p>
            <p style="font-size:15px;font-weight:500;color:#0F172A;margin:0;">3 Anderson Close</p>
            <p style="font-size:15px;color:#334155;margin:2px 0 0;">Harefield, Middlesex UB9 6HF</p>
          </div>
        </div>
      </div>
      <div style="background:#F8FAFC;border:1px solid #E2E8F0;border-radius:8px;padding:24px;">
        <h4 style="font-family:'Lexend',sans-serif;font-size:16px;font-weight:600;color:#0F172A;margin:0 0 12px;letter-spacing:-0.02em;">Service area</h4>
        <p style="font-size:14px;color:#334155;line-height:1.65;margin:0 0 16px;">We cover 27 areas across Middlesex and the Home Counties — from Stanmore and Watford to Bracknell, Farnham, and Ascot.</p>
        <a href="/areas" style="font-size:14px;font-weight:500;color:#0C7BA8;text-decoration:none;">View all areas →</a>
      </div>
    </div>
  </div>
</section>

<!-- MAP -->
<section style="padding:0 0 0;background:#ffffff;">
  <div style="max-width:1280px;margin:0 auto;padding:0 24px 96px;">
    <h2 style="font-family:'Lexend',sans-serif;font-size:clamp(22px,3vw,30px);font-weight:600;color:#0F172A;margin:0 0 8px;letter-spacing:-0.03em;">Where we're based</h2>
    <p style="font-size:15px;color:#64748B;margin:0 0 24px;line-height:1.6;">3 Anderson Close, Harefield, Middlesex UB9 6HF — covering Middlesex and the Home Counties.</p>
    <div style="border-radius:12px;overflow:hidden;border:1px solid #E2E8F0;line-height:0;">
      <iframe
        title="Map showing Hancock Plastering & Painting Services in Harefield, Middlesex"
        src="https://maps.google.com/maps?q=3%20Anderson%20Close%2C%20Harefield%2C%20Middlesex%20UB9%206HF&z=14&output=embed"
        width="100%"
        height="420"
        style="border:0;display:block;"
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        allowfullscreen
      ></iframe>
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    const form = document.getElementById('contact-form');
    const wrap = document.getElementById('contact-form-wrap');
    const success = document.getElementById('contact-success');
    const errorBox = document.getElementById('contact-error');
    const btn = document.getElementById('contact-submit');
    if (!form) return;

    function showError(msg) {
      errorBox.textContent = msg;
      errorBox.style.display = 'block';
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      errorBox.style.display = 'none';

      const data = new FormData(form);
      if (!data.get('access_key')) {
        showError('The contact form is not set up yet. Please call 07734 903439 or email hancockplasteringpainting@gmail.com directly.');
        return;
      }

      const originalText = btn.innerHTML;
      btn.disabled = true;
      btn.style.opacity = '0.6';
      btn.style.cursor = 'wait';
      btn.innerHTML = 'Sending…';

      try {
        const res = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          headers: { Accept: 'application/json' },
          body: data,
        });
        const json = await res.json();
        if (res.ok && json.success) {
          wrap.style.display = 'none';
          success.style.display = 'block';
          success.scrollIntoView({ behavior: 'smooth', block: 'center' });
        } else {
          throw new Error(json.message || 'Submission failed');
        }
      } catch (err) {
        showError('Sorry, something went wrong sending your enquiry. Please call 07734 903439 or email hancockplasteringpainting@gmail.com.');
        btn.disabled = false;
        btn.style.opacity = '1';
        btn.style.cursor = 'pointer';
        btn.innerHTML = originalText;
      }
    });
  })();
</script>
</Layout>
