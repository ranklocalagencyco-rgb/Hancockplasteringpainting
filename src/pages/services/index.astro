---
import Layout from '../../layouts/Layout.astro';
---

<Layout title='Our Services | Hancock Plastering & Painting Services' description='Plastering, rendering, skimming, painting and decorating across Middlesex and the Home Counties. Fixed-price quotes, certified tradespeople.' activePage='services'>
<!-- HERO -->
<section style="position:relative;height:400px;display:flex;align-items:flex-end;">
  <div style="position:absolute;top:0;left:0;right:0;bottom:0;background-image:url('/uploads/Hancock-plastering-and-painting%20(13).webp');background-size:cover;background-position:center 30%;"></div>
  <div style="position:absolute;top:0;left:0;right:0;bottom:0;background:linear-gradient(to top,rgba(15,23,42,0.9) 0%,rgba(15,23,42,0.45) 55%,rgba(15,23,42,0.15) 100%);"></div>
  <div style="position:relative;z-index:1;max-width:1280px;margin:0 auto;padding:0 24px 56px;width:100%;box-sizing:border-box;">
    <p style="font-size:12px;color:rgba(255,255,255,0.55);margin:0 0 12px;"><a href="/" style="color:rgba(255,255,255,0.55);text-decoration:none;">Home</a> / Services</p>
    <h1 style="font-family:'Lexend',sans-serif;font-size:clamp(36px,5vw,60px);font-weight:700;color:#ffffff;margin:0 0 16px;letter-spacing:-0.04em;line-height:1.05;">14 services.<br>One team.</h1>
    <p style="font-size:18px;color:rgba(255,255,255,0.75);margin:0;max-width:500px;line-height:1.5;">Plastering and painting for homeowners, developers, and landlords across Middlesex and the Home Counties.</p>
  </div>
</section>

<!-- PLASTERING -->
<section style="padding:80px 24px;background:#ffffff;">
  <div style="max-width:1280px;margin:0 auto;">
    <div style="display:flex;align-items:center;gap:16px;margin-bottom:40px;padding-bottom:24px;border-bottom:1px solid #E2E8F0;">
      <div style="width:4px;height:36px;background:#0C7BA8;border-radius:2px;flex-shrink:0;"></div>
      <h2 style="font-family:'Lexend',sans-serif;font-size:clamp(24px,3vw,34px);font-weight:600;color:#0F172A;margin:0;letter-spacing:-0.03em;">Plastering Services</h2>
    </div>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:20px;">
      <a href="/services/rendering" style="display:block;background:#ffffff;border:1px solid #E2E8F0;border-radius:8px;padding:28px;text-decoration:none;" style-hover="box-shadow:0 4px 20px rgba(0,0,0,0.07);border-color:#D0E7F5;">
        <h3 style="font-family:'Lexend',sans-serif;font-size:18px;font-weight:600;color:#0F172A;margin:0 0 10px;letter-spacing:-0.02em;">Rendering</h3>
        <p style="font-size:14px;color:#64748B;line-height:1.65;margin:0 0 16px;">External render — sand and cement, monocouche, and pebble dash applied properly to Middlesex and Home Counties properties.rvice in the set.</p>
        <span style="font-size:14px;font-weight:500;color:#0C7BA8;">View service →</span>
      </a>
      <a href="/services/plastering" style="display:block;background:#ffffff;border:1px solid #E2E8F0;border-radius:8px;padding:28px;text-decoration:none;" style-hover="box-shadow:0 4px 20px rgba(0,0,0,0.07);border-color:#D0E7F5;">
        <h3 style="font-family:'Lexend',sans-serif;font-size:18px;font-weight:600;color:#0F172A;margin:0 0 10px;letter-spacing:-0.02em;">Plastering</h3>
        <p style="font-size:14px;color:#64748B;line-height:1.65;margin:0 0 16px;">Full plastering across all substrates — new build, renovation, Victorian solid brick. Prepared and finished flat.</p>
        <span style="font-size:14px;font-weight:500;color:#0C7BA8;">View service →</span>
      </a>
      <a href="/services/skimming" style="display:block;background:#ffffff;border:1px solid #E2E8F0;border-radius:8px;padding:28px;text-decoration:none;" style-hover="box-shadow:0 4px 20px rgba(0,0,0,0.07);border-color:#D0E7F5;">
        <h3 style="font-family:'Lexend',sans-serif;font-size:18px;font-weight:600;color:#0F172A;margin:0 0 10px;letter-spacing:-0.02em;">Skimming</h3>
        <p style="font-size:14px;color:#64748B;line-height:1.65;margin:0 0 16px;">Skim plastering over existing plaster, plasterboard, or bonding coat. Done flat and consistently.op service.</p>
        <span style="font-size:14px;font-weight:500;color:#0C7BA8;">View service →</span>
      </a>
      <a href="/services/venetian-plastering" style="display:block;background:#ffffff;border:1px solid #E2E8F0;border-radius:8px;padding:28px;text-decoration:none;" style-hover="box-shadow:0 4px 20px rgba(0,0,0,0.07);border-color:#D0E7F5;">
        <h3 style="font-family:'Lexend',sans-serif;font-size:18px;font-weight:600;color:#0F172A;margin:0 0 10px;letter-spacing:-0.02em;">Venetian Plastering</h3>
        <p style="font-size:14px;color:#64748B;line-height:1.65;margin:0 0 16px;">Polished plaster and marmorino finishes for high-end properties in Windsor, Ascot, and Gerrards Cross.</p>
        <span style="font-size:14px;font-weight:500;color:#0C7BA8;">View service →</span>
      </a>
      <a href="/services/pebble-dashing" style="display:block;background:#ffffff;border:1px solid #E2E8F0;border-radius:8px;padding:28px;text-decoration:none;" style-hover="box-shadow:0 4px 20px rgba(0,0,0,0.07);border-color:#D0E7F5;">
        <h3 style="font-family:'Lexend',sans-serif;font-size:18px;font-weight:600;color:#0F172A;margin:0 0 10px;letter-spacing:-0.02em;">Pebble Dashing</h3>
        <p style="font-size:14px;color:#64748B;line-height:1.65;margin:0 0 16px;">Full strip and re-dash or targeted patch repairs. One of the most common external wall issues on Middlesex's postwar housing stock.</p>
        <span style="font-size:14px;font-weight:500;color:#0C7BA8;">View service →</span>
      </a>
      <a href="/services/floating-plaster" style="display:block;background:#ffffff;border:1px solid #E2E8F0;border-radius:8px;padding:28px;text-decoration:none;" style-hover="box-shadow:0 4px 20px rgba(0,0,0,0.07);border-color:#D0E7F5;">
        <h3 style="font-family:'Lexend',sans-serif;font-size:18px;font-weight:600;color:#0F172A;margin:0 0 10px;letter-spacing:-0.02em;">Floating Plaster</h3>
        <p style="font-size:14px;color:#64748B;line-height:1.65;margin:0 0 16px;">The base coat that determines whether the final skim holds flat. Floating done properly before skimming.</p>
        <span style="font-size:14px;font-weight:500;color:#0C7BA8;">View service →</span>
      </a>
      <a href="/services/plaster-refurbishment" style="display:block;background:#ffffff;border:1px solid #E2E8F0;border-radius:8px;padding:28px;text-decoration:none;" style-hover="box-shadow:0 4px 20px rgba(0,0,0,0.07);border-color:#D0E7F5;">
        <h3 style="font-family:'Lexend',sans-serif;font-size:18px;font-weight:600;color:#0F172A;margin:0 0 10px;letter-spacing:-0.02em;">Plaster Refurbishment</h3>
        <p style="font-size:14px;color:#64748B;line-height:1.65;margin:0 0 16px;">Blown plaster, cracked ceilings, failed previous repairs. Strip and replaster done right rather than patched over.</p>
        <span style="font-size:14px;font-weight:500;color:#0C7BA8;">View service →</span>
      </a>
      <a href="/services/repair-insurance" style="display:block;background:#ffffff;border:1px solid #E2E8F0;border-radius:8px;padding:28px;text-decoration:none;" style-hover="box-shadow:0 4px 20px rgba(0,0,0,0.07);border-color:#D0E7F5;">
        <h3 style="font-family:'Lexend',sans-serif;font-size:18px;font-weight:600;color:#0F172A;margin:0 0 10px;letter-spacing:-0.02em;">Repair &amp; Insurance Work</h3>
        <p style="font-size:14px;color:#64748B;line-height:1.65;margin:0 0 16px;">Plaster and paint damage from water ingress, subsidence, or accidental damage. Documented work for insurers.</p>
        <span style="font-size:14px;font-weight:500;color:#0C7BA8;">View service →</span>
      </a>
    </div>
  </div>
</section>

<!-- PAINTING -->
<section style="padding:0 24px 80px;background:#ffffff;">
  <div style="max-width:1280px;margin:0 auto;">
    <div style="display:flex;align-items:center;gap:16px;margin-bottom:40px;padding-bottom:24px;border-bottom:1px solid #E2E8F0;">
      <div style="width:4px;height:36px;background:#0C7BA8;border-radius:2px;flex-shrink:0;"></div>
      <h2 style="font-family:'Lexend',sans-serif;font-size:clamp(24px,3vw,34px);font-weight:600;color:#0F172A;margin:0;letter-spacing:-0.03em;">Painting &amp; Decorating</h2>
    </div>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:20px;">
      <a href="/services/exterior-painting" style="display:block;background:#ffffff;border:1px solid #E2E8F0;border-radius:8px;padding:28px;text-decoration:none;" style-hover="box-shadow:0 4px 20px rgba(0,0,0,0.07);border-color:#D0E7F5;">
        <h3 style="font-family:'Lexend',sans-serif;font-size:18px;font-weight:600;color:#0F172A;margin:0 0 10px;letter-spacing:-0.02em;">Exterior Painting</h3>
        <p style="font-size:14px;color:#64748B;line-height:1.65;margin:0 0 16px;">Weather-resistant exterior finishes that protect the property and look right for years, not seasons.</p>
        <span style="font-size:14px;font-weight:500;color:#0C7BA8;">View service →</span>
      </a>
      <a href="/services/interior-painting" style="display:block;background:#ffffff;border:1px solid #E2E8F0;border-radius:8px;padding:28px;text-decoration:none;" style-hover="box-shadow:0 4px 20px rgba(0,0,0,0.07);border-color:#D0E7F5;">
        <h3 style="font-family:'Lexend',sans-serif;font-size:18px;font-weight:600;color:#0F172A;margin:0 0 10px;letter-spacing:-0.02em;">Interior Painting</h3>
        <p style="font-size:14px;color:#64748B;line-height:1.65;margin:0 0 16px;">Interior painting done with proper preparation. Filled, sanded, primed. No shortcuts that show under spotlighting.</p>
        <span style="font-size:14px;font-weight:500;color:#0C7BA8;">View service →</span>
      </a>
      <a href="/services/wallpapering" style="display:block;background:#ffffff;border:1px solid #E2E8F0;border-radius:8px;padding:28px;text-decoration:none;" style-hover="box-shadow:0 4px 20px rgba(0,0,0,0.07);border-color:#D0E7F5;">
        <h3 style="font-family:'Lexend',sans-serif;font-size:18px;font-weight:600;color:#0F172A;margin:0 0 10px;letter-spacing:-0.02em;">Wallpapering</h3>
        <p style="font-size:14px;color:#64748B;line-height:1.65;margin:0 0 16px;">Straight drops, matched patterns, tight seams. Feature walls and full-room wallpapering done precisely.</p>
        <span style="font-size:14px;font-weight:500;color:#0C7BA8;">View service →</span>
      </a>
      <a href="/services/sash-window-painting" style="display:block;background:#ffffff;border:1px solid #E2E8F0;border-radius:8px;padding:28px;text-decoration:none;" style-hover="box-shadow:0 4px 20px rgba(0,0,0,0.07);border-color:#D0E7F5;">
        <h3 style="font-family:'Lexend',sans-serif;font-size:18px;font-weight:600;color:#0F172A;margin:0 0 10px;letter-spacing:-0.02em;">Sash Window Painting</h3>
        <p style="font-size:14px;color:#64748B;line-height:1.65;margin:0 0 16px;">Period properties across Windsor and Gerrards Cross have sash windows that need proper preparation and the right paint system.</p>
        <span style="font-size:14px;font-weight:500;color:#0C7BA8;">View service →</span>
      </a>
      <a href="/services/commercial-decorating" style="display:block;background:#ffffff;border:1px solid #E2E8F0;border-radius:8px;padding:28px;text-decoration:none;" style-hover="box-shadow:0 4px 20px rgba(0,0,0,0.07);border-color:#D0E7F5;">
        <h3 style="font-family:'Lexend',sans-serif;font-size:18px;font-weight:600;color:#0F172A;margin:0 0 10px;letter-spacing:-0.02em;">Commercial Decorating</h3>
        <p style="font-size:14px;color:#64748B;line-height:1.65;margin:0 0 16px;">Offices, rental properties, and commercial spaces. Deadlines matter. We work around tenants and handover dates.</p>
        <span style="font-size:14px;font-weight:500;color:#0C7BA8;">View service →</span>
      </a>
      <a href="/services/eco-friendly-decorating" style="display:block;background:#ffffff;border:1px solid #E2E8F0;border-radius:8px;padding:28px;text-decoration:none;" style-hover="box-shadow:0 4px 20px rgba(0,0,0,0.07);border-color:#D0E7F5;">
        <h3 style="font-family:'Lexend',sans-serif;font-size:18px;font-weight:600;color:#0F172A;margin:0 0 10px;letter-spacing:-0.02em;">Eco-Friendly Decorating</h3>
        <p style="font-size:14px;color:#64748B;line-height:1.65;margin:0 0 16px;">Low-VOC and eco paint systems for clients who want minimal chemical exposure without compromising on quality.</p>
        <span style="font-size:14px;font-weight:500;color:#0C7BA8;">View service →</span>
      </a>
    </div>
  </div>
</section>

<!-- CTA -->
<section style="padding:80px 24px;background:#0F172A;">
  <div style="max-width:720px;margin:0 auto;text-align:center;">
    <h2 style="font-family:'Lexend',sans-serif;font-size:clamp(28px,4vw,44px);font-weight:700;color:#ffffff;margin:0 0 20px;letter-spacing:-0.04em;line-height:1.1;">Not sure which service you need?</h2>
    <p style="font-size:17px;color:rgba(255,255,255,0.65);margin:0 0 40px;line-height:1.65;">Call Oliver directly — he'll tell you straight what the job needs and give you an honest price.</p>
    <div style="display:flex;gap:14px;justify-content:center;flex-wrap:wrap;">
      <a href="/contact" style="display:inline-flex;align-items:center;background:#0C7BA8;color:#ffffff;font-size:16px;font-weight:600;padding:15px 30px;border-radius:6px;text-decoration:none;">Get a Free Quote</a>
      <a href="tel:07734903439" style="display:inline-flex;align-items:center;background:rgba(255,255,255,0.08);color:#ffffff;font-size:16px;font-weight:500;padding:15px 30px;border-radius:6px;text-decoration:none;border:1px solid rgba(255,255,255,0.18);">07734 903439</a>
    </div>
  </div>
</section>
</Layout>
