---
import Layout from '../../layouts/Layout.astro';
import ServicesGrid from '../../components/ServicesGrid.astro';
---

<Layout title='Our Services | Hancock Plastering & Painting Services' description='Plastering, rendering, skimming, painting and decorating across Middlesex and the Home Counties. Fixed-price quotes, certified tradespeople.' activePage='services'>
<!-- HERO -->
<section style="position:relative;height:400px;display:flex;align-items:flex-end;">
  <div style="position:absolute;top:0;left:0;right:0;bottom:0;background-image:url('/uploads/Hancock-plastering-and-painting%20(13).webp');background-size:cover;background-position:center 30%;"></div>
  <div style="position:absolute;top:0;left:0;right:0;bottom:0;background:linear-gradient(to top,rgba(15,23,42,0.9) 0%,rgba(15,23,42,0.45) 55%,rgba(15,23,42,0.15) 100%);"></div>
  <div style="position:relative;z-index:1;max-width:1280px;margin:0 auto;padding:0 24px 56px;width:100%;box-sizing:border-box;">
    <p style="font-size:12px;color:rgba(255,255,255,0.55);margin:0 0 12px;"><a href="/" style="color:rgba(255,255,255,0.55);text-decoration:none;">Home</a> / Services</p>
    <h1 style="font-family:'Lexend',sans-serif;font-size:clamp(36px,5vw,60px);font-weight:700;color:#ffffff;margin:0 0 16px;letter-spacing:-0.04em;line-height:1.05;">14 services.<br>One team.</h1>
    <p style="font-size:18px;color:rgba(255,255,255,0.75);margin:0;max-width:500px;line-height:1.5;">Plastering and painting for homeowners, developers, and landlords across Middlesex and the Home Counties.</p>
  </div>
</section>

<ServicesGrid />

<!-- CTA -->
<section style="padding:80px 24px;background:#0F172A;">
  <div style="max-width:720px;margin:0 auto;text-align:center;">
    <h2 style="font-family:'Lexend',sans-serif;font-size:clamp(28px,4vw,44px);font-weight:700;color:#ffffff;margin:0 0 20px;letter-spacing:-0.04em;line-height:1.1;">Not sure which service you need?</h2>
    <p style="font-size:17px;color:rgba(255,255,255,0.65);margin:0 0 40px;line-height:1.65;">Call Oliver directly — he'll tell you straight what the job needs and give you an honest price.</p>
    <div style="display:flex;gap:14px;justify-content:center;flex-wrap:wrap;">
      <a href="/contact" style="display:inline-flex;align-items:center;background:#0C7BA8;color:#ffffff;font-size:16px;font-weight:600;padding:15px 30px;border-radius:6px;text-decoration:none;">Get a Free Quote</a>
      <a href="tel:07734903439" style="display:inline-flex;align-items:center;background:rgba(255,255,255,0.08);color:#ffffff;font-size:16px;font-weight:500;padding:15px 30px;border-radius:6px;text-decoration:none;border:1px solid rgba(255,255,255,0.18);">07734 903439</a>
    </div>
  </div>
</section>
</Layout>
