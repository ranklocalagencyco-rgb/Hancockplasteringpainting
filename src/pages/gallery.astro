---
import Layout from '../layouts/Layout.astro';
import BlogInsights from '../components/BlogInsights.astro';
import Cta from '../components/Cta.astro';
import { readdirSync } from 'node:fs';
import { join } from 'node:path';

// Reads every image in /public/gallery at build time — drop new photos in that
// folder and they appear here automatically (no code changes needed).
const galleryDir = join(process.cwd(), 'public', 'gallery');
let files: string[] = [];
try {
  files = readdirSync(galleryDir)
    .filter((f) => /\.(webp|jpe?g|png|avif)$/i.test(f))
    .sort((a, b) => a.localeCompare(b, undefined, { numeric: true }));
} catch {
  files = [];
}
const images = files.map((f) => '/gallery/' + encodeURIComponent(f));
---

<Layout
  title="Recent Work Gallery | Hancock Plastering & Painting Services"
  description="Browse recent plastering, rendering, skimming and painting projects completed by Hancock across Middlesex and the Home Counties."
  activePage="gallery"
>
<!-- HERO -->
<section style="position:relative;height:340px;display:flex;align-items:flex-end;">
  <div style="position:absolute;top:0;left:0;right:0;bottom:0;background-image:url('/uploads/Hancock-plastering-and-painting%20(12).webp');background-size:cover;background-position:center 35%;"></div>
  <div style="position:absolute;top:0;left:0;right:0;bottom:0;background:linear-gradient(to top,rgba(15,23,42,0.92) 0%,rgba(15,23,42,0.5) 55%,rgba(15,23,42,0.18) 100%);"></div>
  <div style="position:relative;z-index:1;max-width:1280px;margin:0 auto;padding:0 24px 52px;width:100%;box-sizing:border-box;">
    <p style="font-size:12px;color:rgba(255,255,255,0.55);margin:0 0 12px;"><a href="/" style="color:rgba(255,255,255,0.55);text-decoration:none;">Home</a> / Gallery</p>
    <h1 style="font-family:'Lexend',sans-serif;font-size:clamp(32px,5vw,54px);font-weight:700;color:#ffffff;margin:0 0 12px;letter-spacing:-0.04em;line-height:1.05;">Recent work.</h1>
    <p style="font-size:17px;color:rgba(255,255,255,0.72);margin:0;">Plastering, rendering and painting projects across Middlesex and the Home Counties.</p>
  </div>
</section>

<!-- GALLERY GRID -->
<section style="padding:72px 24px 96px;background:#ffffff;">
  <div style="max-width:1280px;margin:0 auto;">
    {images.length === 0 ? (
      <div style="text-align:center;padding:60px 20px;background:#F8FAFC;border:1px dashed #CBD5E1;border-radius:8px;">
        <p style="font-family:'Lexend',sans-serif;font-size:20px;font-weight:600;color:#0F172A;margin:0 0 8px;">No photos yet</p>
        <p style="font-size:15px;color:#64748B;margin:0;">Add image files to <code>public/gallery/</code> and they'll appear here automatically.</p>
      </div>
    ) : (
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:16px;">
        {images.map((src, i) => (
          <button
            class="gallery-thumb"
            data-index={i}
            style="position:relative;border:none;padding:0;margin:0;cursor:pointer;border-radius:8px;overflow:hidden;aspect-ratio:4/3;background:#F1F5F9;display:block;"
          >
            <img
              src={src}
              alt={`Hancock plastering and painting — recent work ${i + 1}`}
              title={`Hancock plastering and painting — recent work ${i + 1}`}
              loading="lazy"
              style="width:100%;height:100%;object-fit:cover;display:block;transition:transform 0.4s ease;"
            />
          </button>
        ))}
      </div>
    )}
  </div>
</section>

<Cta />
<BlogInsights />

<!-- LIGHTBOX -->
<div id="lightbox" style="display:none;position:fixed;inset:0;z-index:2000;background:rgba(15,23,42,0.94);align-items:center;justify-content:center;">
  <button id="lb-close" aria-label="Close" style="position:absolute;top:20px;right:24px;background:none;border:none;color:#ffffff;font-size:34px;line-height:1;cursor:pointer;">×</button>
  <button id="lb-prev" aria-label="Previous" style="position:absolute;left:16px;top:50%;transform:translateY(-50%);background:rgba(255,255,255,0.1);border:none;color:#ffffff;font-size:28px;width:48px;height:48px;border-radius:50%;cursor:pointer;">‹</button>
  <img id="lb-img" src="" alt="Hancock plastering and painting work — enlarged view" title="Hancock plastering and painting work — enlarged view" style="max-width:90vw;max-height:85vh;object-fit:contain;border-radius:6px;box-shadow:0 10px 40px rgba(0,0,0,0.5);" />
  <button id="lb-next" aria-label="Next" style="position:absolute;right:16px;top:50%;transform:translateY(-50%);background:rgba(255,255,255,0.1);border:none;color:#ffffff;font-size:28px;width:48px;height:48px;border-radius:50%;cursor:pointer;">›</button>
</div>

<style>
  .gallery-thumb:hover img { transform: scale(1.05); }
</style>

<script is:inline define:vars={{ images }}>
  (function () {
    if (!images || images.length === 0) return;
    const lb = document.getElementById('lightbox');
    const lbImg = document.getElementById('lb-img');
    let current = 0;

    function open(i) {
      current = i;
      lbImg.src = images[current];
      lb.style.display = 'flex';
      document.body.style.overflow = 'hidden';
    }
    function close() {
      lb.style.display = 'none';
      document.body.style.overflow = '';
    }
    function show(delta) {
      current = (current + delta + images.length) % images.length;
      lbImg.src = images[current];
    }

    document.querySelectorAll('.gallery-thumb').forEach((btn) => {
      btn.addEventListener('click', () => open(parseInt(btn.dataset.index, 10)));
    });
    document.getElementById('lb-close').addEventListener('click', close);
    document.getElementById('lb-prev').addEventListener('click', (e) => { e.stopPropagation(); show(-1); });
    document.getElementById('lb-next').addEventListener('click', (e) => { e.stopPropagation(); show(1); });
    lb.addEventListener('click', (e) => { if (e.target === lb) close(); });
    document.addEventListener('keydown', (e) => {
      if (lb.style.display !== 'flex') return;
      if (e.key === 'Escape') close();
      else if (e.key === 'ArrowLeft') show(-1);
      else if (e.key === 'ArrowRight') show(1);
    });
  })();
</script>
</Layout>
