---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const latestPosts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const fmtDate = (d: Date) =>
  d.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });

// All 14 services shown on the homepage (mirrors the /services hub).
const services = [
  { href: '/services/rendering', name: 'Rendering', desc: 'External render — sand and cement, monocouche, and pebble dash applied properly.', icon: `<rect x="2" y="4" width="16" height="12" rx="1" stroke="#0F172A" stroke-width="1.5"></rect><line x1="2" y1="9" x2="18" y2="9" stroke="#0F172A" stroke-width="1"></line><line x1="9" y1="4" x2="9" y2="9" stroke="#0F172A" stroke-width="1"></line><line x1="6" y1="9" x2="6" y2="16" stroke="#0F172A" stroke-width="1"></line><line x1="13" y1="9" x2="13" y2="16" stroke="#0F172A" stroke-width="1"></line>` },
  { href: '/services/plastering', name: 'Plastering', desc: 'Full plastering across all substrates — prepared and finished flat, ready for paint or paper.', icon: `<rect x="2" y="5" width="12" height="8" rx="1" stroke="#0F172A" stroke-width="1.5"></rect><line x1="14" y1="9" x2="18" y2="13" stroke="#0F172A" stroke-width="2" stroke-linecap="round"></line>` },
  { href: '/services/skimming', name: 'Skimming', desc: 'Skim plastering over existing walls, plasterboard or bonding — flat and consistent.', icon: `<path d="M3 15L13 5" stroke="#0F172A" stroke-width="1.5" stroke-linecap="round"></path><path d="M11 3l4 4-2.5 2.5-4-4z" stroke="#0F172A" stroke-width="1.5" stroke-linejoin="round"></path>` },
  { href: '/services/venetian-plastering', name: 'Venetian Plastering', desc: 'Polished plaster for high-end interiors across Windsor, Gerrards Cross and Ascot.', icon: `<path d="M10 2L11.8 7.5H17.5L12.9 10.8L14.6 16.5L10 13.2L5.4 16.5L7.1 10.8L2.5 7.5H8.2L10 2Z" stroke="#0F172A" stroke-width="1.5" stroke-linejoin="round"></path>` },
  { href: '/services/pebble-dashing', name: 'Pebble Dashing', desc: 'Full strip and re-dash or targeted patch repairs to external walls.', icon: `<circle cx="5" cy="6" r="1.1" stroke="#0F172A" stroke-width="1.2"></circle><circle cx="10" cy="5" r="1.1" stroke="#0F172A" stroke-width="1.2"></circle><circle cx="15" cy="7" r="1.1" stroke="#0F172A" stroke-width="1.2"></circle><circle cx="6" cy="11" r="1.1" stroke="#0F172A" stroke-width="1.2"></circle><circle cx="11" cy="11" r="1.1" stroke="#0F172A" stroke-width="1.2"></circle><circle cx="15" cy="13" r="1.1" stroke="#0F172A" stroke-width="1.2"></circle><circle cx="8" cy="15" r="1.1" stroke="#0F172A" stroke-width="1.2"></circle>` },
  { href: '/services/floating-plaster', name: 'Floating Plaster', desc: 'The base coat that keeps the final skim flat — floating done properly first.', icon: `<path d="M10 3l7 3.5-7 3.5-7-3.5z" stroke="#0F172A" stroke-width="1.5" stroke-linejoin="round"></path><path d="M3 11l7 3.5 7-3.5" stroke="#0F172A" stroke-width="1.5" stroke-linejoin="round"></path>` },
  { href: '/services/plaster-refurbishment', name: 'Plaster Refurbishment', desc: 'Blown plaster and cracked ceilings stripped and re-plastered, not patched over.', icon: `<rect x="3" y="3" width="14" height="14" rx="1" stroke="#0F172A" stroke-width="1.5"></rect><path d="M10 3l-2 4 3 2-2 4 2 4" stroke="#0F172A" stroke-width="1.2" stroke-linejoin="round"></path>` },
  { href: '/services/repair-insurance', name: 'Repair & Insurance Work', desc: 'Plaster and paint damage from water, subsidence or accidents — documented for insurers.', icon: `<path d="M10 2l6 2.2v4.8c0 4-2.8 6.8-6 8.5-3.2-1.7-6-4.5-6-8.5V4.2z" stroke="#0F172A" stroke-width="1.5" stroke-linejoin="round"></path><path d="M7.2 9.5l2 2 3.6-3.8" stroke="#0F172A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>` },
  { href: '/services/exterior-painting', name: 'Exterior Painting', desc: 'Weather-resistant finishes that protect the property and hold up for years.', icon: `<path d="M2 9L10 2L18 9" stroke="#0F172A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path><path d="M4 8V18H16V8" stroke="#0F172A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path><rect x="8" y="12" width="4" height="6" stroke="#0F172A" stroke-width="1.5"></rect>` },
  { href: '/services/interior-painting', name: 'Interior Painting', desc: 'Clean, even, properly prepared — no shortcuts that show under spotlighting.', icon: `<rect x="2" y="2" width="14" height="6" rx="1" stroke="#0F172A" stroke-width="1.5"></rect><line x1="9" y1="8" x2="9" y2="13" stroke="#0F172A" stroke-width="1.5"></line><line x1="9" y1="13" x2="14" y2="13" stroke="#0F172A" stroke-width="1.5" stroke-linecap="round"></line><line x1="14" y1="13" x2="14" y2="18" stroke="#0F172A" stroke-width="1.5" stroke-linecap="round"></line>` },
  { href: '/services/wallpapering', name: 'Wallpapering', desc: 'Straight drops, matched patterns and tight seams — feature walls and full rooms.', icon: `<rect x="4" y="3" width="10" height="6" rx="1" stroke="#0F172A" stroke-width="1.5"></rect><path d="M14 5c1.5 0 2 .5 2 2v8a2 2 0 01-4 0V9" stroke="#0F172A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>` },
  { href: '/services/sash-window-painting', name: 'Sash Window Painting', desc: 'The prep and paint system period sash windows need to last beyond one winter.', icon: `<rect x="3" y="2" width="14" height="16" rx="1" stroke="#0F172A" stroke-width="1.5"></rect><line x1="10" y1="2" x2="10" y2="18" stroke="#0F172A" stroke-width="1.5"></line><line x1="3" y1="10" x2="17" y2="10" stroke="#0F172A" stroke-width="1.5"></line>` },
  { href: '/services/commercial-decorating', name: 'Commercial Decorating', desc: 'Offices, rentals and commercial spaces — we work around tenants and handover dates.', icon: `<rect x="4" y="2" width="12" height="16" rx="1" stroke="#0F172A" stroke-width="1.5"></rect><line x1="7" y1="5" x2="8.5" y2="5" stroke="#0F172A" stroke-width="1.3"></line><line x1="11.5" y1="5" x2="13" y2="5" stroke="#0F172A" stroke-width="1.3"></line><line x1="7" y1="8.5" x2="8.5" y2="8.5" stroke="#0F172A" stroke-width="1.3"></line><line x1="11.5" y1="8.5" x2="13" y2="8.5" stroke="#0F172A" stroke-width="1.3"></line><line x1="7" y1="12" x2="8.5" y2="12" stroke="#0F172A" stroke-width="1.3"></line><line x1="11.5" y1="12" x2="13" y2="12" stroke="#0F172A" stroke-width="1.3"></line><line x1="8.5" y1="18" x2="11.5" y2="18" stroke="#0F172A" stroke-width="1.5"></line>` },
  { href: '/services/eco-friendly-decorating', name: 'Eco-Friendly Decorating', desc: 'Low-VOC and eco paint systems for minimal chemical exposure, no compromise on quality.', icon: `<path d="M16 4c0 7-4 12-11 12 0-7 4-12 11-12z" stroke="#0F172A" stroke-width="1.5" stroke-linejoin="round"></path><path d="M5 16c3-4 6-6 9-8" stroke="#0F172A" stroke-width="1.3" stroke-linecap="round"></path>` },
];
