<section style="padding:64px 24px;background:#0F172A;">
  <div style="max-width:720px;margin:0 auto;text-align:center;">
    <h2 style="font-family:'Lexend',sans-serif;font-size:clamp(26px,4vw,40px);font-weight:700;color:#ffffff;margin:0 0 16px;letter-spacing:-0.04em;">Get a quote for work in Uxbridge.</h2>
    <p style="font-family:'Inter',sans-serif;font-size:16px;color:rgba(255,255,255,0.65);margin:0 0 36px;">Domestic and commercial. Fixed price. Based in nearby Harefield.</p>
