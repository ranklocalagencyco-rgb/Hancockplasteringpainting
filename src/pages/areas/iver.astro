    <div style="margin-top:20px;"><p style="font-family:'Inter',sans-serif;font-size:13px;font-weight:600;color:#64748B;text-transform:uppercase;letter-spacing:0.08em;margin:0 0 12px;">Nearby</p><div style="display:flex;flex-wrap:wrap;gap:8px;"><a href="/areas/harefield" style="padding:6px 13px;background:#ffffff;border:1px solid #E2E8F0;border-radius:4px;font-family:'Inter',sans-serif;font-size:13px;color:#334155;text-decoration:none;">Harefield</a><a href="/areas/denham" style="padding:6px 13px;background:#ffffff;border:1px solid #E2E8F0;border-radius:4px;font-family:'Inter',sans-serif;font-size:13px;color:#334155;text-decoration:none;">Denham</a><a href="/areas/uxbridge" style="padding:6px 13px;background:#ffffff;border:1px solid #E2E8F0;border-radius:4px;font-family:'Inter',sans-serif;font-size:13px;color:#334155;text-decoration:none;">Uxbridge</a></div></div>
  </div>
</section>
<section style="padding:56px 24px;background:#0F172A;">
  <div style="max-width:720px;margin:0 auto;text-align:center;">
    <h2 style="font-family:'Lexend',sans-serif;font-size:clamp(24px,4vw,36px);font-weight:700;color:#ffffff;margin:0 0 14px;letter-spacing:-0.04em;">Get a quote for work in Iver.</h2>
