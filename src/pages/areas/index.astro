<Layout title='Areas We Cover | Hancock Plastering & Painting Services' description='We cover Middlesex and the Home Counties — Ruislip, Watford, Uxbridge, Windsor, Gerrards Cross and many more. Find your area.' activePage='areas'>
<!-- HERO -->
<section style="position:relative;height:400px;display:flex;align-items:flex-end;">
  <div style="position:absolute;top:0;left:0;right:0;bottom:0;background-image:url('/uploads/Hancock-plastering-and-painting%20(3).webp');background-size:cover;background-position:center 40%;"></div>
  <div style="position:absolute;top:0;left:0;right:0;bottom:0;background:linear-gradient(to top,rgba(15,23,42,0.9) 0%,rgba(15,23,42,0.45) 55%,rgba(15,23,42,0.15) 100%);"></div>
  <div style="position:relative;z-index:1;max-width:1280px;margin:0 auto;padding:0 24px 56px;width:100%;box-sizing:border-box;">
    <p style="font-family:'Inter',sans-serif;font-size:12px;color:rgba(255,255,255,0.55);margin:0 0 12px;"><a href="/" style="color:rgba(255,255,255,0.55);text-decoration:none;">Home</a> / Areas We Cover</p>
    <h1 style="font-family:'Lexend',sans-serif;font-size:clamp(36px,5vw,60px);font-weight:700;color:#ffffff;margin:0 0 16px;letter-spacing:-0.04em;line-height:1.05;">26 areas.<br>One corridor.</h1>
