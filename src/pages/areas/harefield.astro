      <a href="/services/exterior-painting" style="padding:16px 20px;background:#F8FAFC;border:1px solid #E2E8F0;border-radius:6px;text-decoration:none;display:flex;align-items:center;gap:10px;" style-hover="background:#E0FAFF;border-color:#0C7BA8;"><span style="color:#0C7BA8;">→</span><span style="font-family:'Inter',sans-serif;font-size:14px;font-weight:500;color:#334155;">Exterior Painting</span></a>
      <a href="/services/venetian-plastering" style="padding:16px 20px;background:#F8FAFC;border:1px solid #E2E8F0;border-radius:6px;text-decoration:none;display:flex;align-items:center;gap:10px;" style-hover="background:#E0FAFF;border-color:#0C7BA8;"><span style="color:#0C7BA8;">→</span><span style="font-family:'Inter',sans-serif;font-size:14px;font-weight:500;color:#334155;">Venetian Plastering</span></a>
    </div>
