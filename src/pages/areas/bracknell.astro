    <div style="position:relative;max-width:1280px;margin:0 auto;height:100%;display:flex;align-items:flex-end;padding:0 24px 40px;box-sizing:border-box;">
      <p style="font-family:'Lexend',sans-serif;font-size:clamp(18px,2.4vw,26px);font-weight:600;color:#ffffff;max-width:600px;margin:0;letter-spacing:-0.02em;line-height:1.3;">Clean, careful decorating — surfaces protected, lines kept crisp.</p>
    </div>
  </div>
</section>
<section style="padding:48px 24px;background:#F8FAFC;border-bottom:1px solid #E2E8F0;">
  <div style="max-width:1280px;margin:0 auto;">
    <p style="font-family:'Inter',sans-serif;font-size:12px;font-weight:600;color:#11ADE2;letter-spacing:0.1em;text-transform:uppercase;margin:0 0 18px;">Services in Bracknell</p>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:10px;">
      <a href="/services/rendering" style="padding:14px 18px;background:#ffffff;border:1px solid #E2E8F0;border-radius:6px;text-decoration:none;display:flex;align-items:center;gap:10px;" style-hover="background:#E0FAFF;border-color:#11ADE2;"><span style="color:#11ADE2;">→</span><span style="font-family:'Inter',sans-serif;font-size:14px;font-weight:500;color:#334155;">Rendering</span></a>
      <a href="/services/pebble-dashing" style="padding:14px 18px;background:#ffffff;border:1px solid #E2E8F0;border-radius:6px;text-decoration:none;display:flex;align-items:center;gap:10px;" style-hover="background:#E0FAFF;border-color:#11ADE2;"><span style="color:#11ADE2;">→</span><span style="font-family:'Inter',sans-serif;font-size:14px;font-weight:500;color:#334155;">Pebble Dashing</span></a>
      <a href="/services/commercial-decorating" style="padding:14px 18px;background:#ffffff;border:1px solid #E2E8F0;border-radius:6px;text-decoration:none;display:flex;align-items:center;gap:10px;" style-hover="background:#E0FAFF;border-color:#11ADE2;"><span style="color:#11ADE2;">→</span><span style="font-family:'Inter',sans-serif;font-size:14px;font-weight:500;color:#334155;">Commercial Decorating</span></a>
      <a href="/services/interior-painting" style="padding:14px 18px;background:#ffffff;border:1px solid #E2E8F0;border-radius:6px;text-decoration:none;display:flex;align-items:center;gap:10px;" style-hover="background:#E0FAFF;border-color:#11ADE2;"><span style="color:#11ADE2;">→</span><span style="font-family:'Inter',sans-serif;font-size:14px;font-weight:500;color:#334155;">Interior Painting</span></a>
    </div>
    <div style="margin-top:20px;"><p style="font-family:'Inter',sans-serif;font-size:13px;font-weight:600;color:#64748B;text-transform:uppercase;letter-spacing:0.08em;margin:0 0 12px;">Nearby</p><div style="display:flex;flex-wrap:wrap;gap:8px;"><a href="/areas/ascot" style="padding:6px 13px;background:#ffffff;border:1px solid #E2E8F0;border-radius:4px;font-family:'Inter',sans-serif;font-size:13px;color:#334155;text-decoration:none;">Ascot</a><a href="/areas/binfield" style="padding:6px 13px;background:#ffffff;border:1px solid #E2E8F0;border-radius:4px;font-family:'Inter',sans-serif;font-size:13px;color:#334155;text-decoration:none;">Binfield</a><a href="/areas/windsor" style="padding:6px 13px;background:#ffffff;border:1px solid #E2E8F0;border-radius:4px;font-family:'Inter',sans-serif;font-size:13px;color:#334155;text-decoration:none;">Windsor</a></div></div>
  </div>
</section>
<section style="padding:56px 24px;background:#0F172A;">
  <div style="max-width:720px;margin:0 auto;text-align:center;">
    <h2 style="font-family:'Lexend',sans-serif;font-size:clamp(24px,4vw,36px);font-weight:700;color:#ffffff;margin:0 0 14px;letter-spacing:-0.04em;">Get a quote for work in Bracknell.</h2>
    <p style="font-family:'Inter',sans-serif;font-size:15px;color:rgba(255,255,255,0.65);margin:0 0 28px;">Domestic and commercial. Fixed price.</p>
    <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;"><a href="/contact" style="display:inline-flex;align-items:center;background:#11ADE2;color:#ffffff;font-family:'Inter',sans-serif;font-size:15px;font-weight:600;padding:13px 26px;border-radius:6px;text-decoration:none;">Get a Free Quote</a><a href="tel:07734903439" style="display:inline-flex;align-items:center;background:rgba(255,255,255,0.08);color:#ffffff;font-family:'Inter',sans-serif;font-size:15px;font-weight:500;padding:13px 26px;border-radius:6px;text-decoration:none;border:1px solid rgba(255,255,255,0.18);">07734 903439</a></div>
  </div>
</section>
