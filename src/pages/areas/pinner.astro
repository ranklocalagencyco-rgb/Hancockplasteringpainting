      <a href="/services/sash-window-painting" style="padding:14px 18px;background:#ffffff;border:1px solid #E2E8F0;border-radius:6px;text-decoration:none;display:flex;align-items:center;gap:10px;" style-hover="background:#E0FAFF;border-color:#11ADE2;"><span style="color:#11ADE2;">→</span><span style="font-family:'Inter',sans-serif;font-size:14px;font-weight:500;color:#334155;">Sash Window Painting</span></a>
      <a href="/services/interior-painting" style="padding:14px 18px;background:#ffffff;border:1px solid #E2E8F0;border-radius:6px;text-decoration:none;display:flex;align-items:center;gap:10px;" style-hover="background:#E0FAFF;border-color:#11ADE2;"><span style="color:#11ADE2;">→</span><span style="font-family:'Inter',sans-serif;font-size:14px;font-weight:500;color:#334155;">Interior Painting</span></a>
    </div>
    <div style="margin-top:20px;"><p style="font-family:'Inter',sans-serif;font-size:13px;font-weight:600;color:#64748B;text-transform:uppercase;letter-spacing:0.08em;margin:0 0 12px;">Nearby</p><div style="display:flex;flex-wrap:wrap;gap:8px;"><a href="/areas/hatch-end" style="padding:6px 13px;background:#ffffff;border:1px solid #E2E8F0;border-radius:4px;font-family:'Inter',sans-serif;font-size:13px;color:#334155;text-decoration:none;">Hatch End</a><a href="/areas/northwood" style="padding:6px 13px;background:#ffffff;border:1px solid #E2E8F0;border-radius:4px;font-family:'Inter',sans-serif;font-size:13px;color:#334155;text-decoration:none;">Northwood</a><a href="/areas/eastcote" style="padding:6px 13px;background:#ffffff;border:1px solid #E2E8F0;border-radius:4px;font-family:'Inter',sans-serif;font-size:13px;color:#334155;text-decoration:none;">Eastcote</a></div></div>
  </div>
</section>
<section style="padding:56px 24px;background:#0F172A;">
  <div style="max-width:720px;margin:0 auto;text-align:center;">
    <h2 style="font-family:'Lexend',sans-serif;font-size:clamp(24px,4vw,38px);font-weight:700;color:#ffffff;margin:0 0 14px;letter-spacing:-0.04em;">Get a quote for work in Pinner.</h2>
